---
/**
 * Chirpy-style topbar: hamburger (mobile only) | breadcrumb | site title (mobile) | search
 * Sits inside the main column, below the header.
 */
import { SITE, type Locale } from '../config';
import { useTranslations, localizedPath, withBase } from '../i18n/utils';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import SearchButton from './islands/SearchButton.astro';
import LanguageSwitcher from './islands/LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  /**
   * Breadcrumb segments. The last segment is treated as the current page.
   * Pass [] to show only "Home".
   */
  crumbs?: Array<{ label: string; href?: string }>;
  /**
   * Locales for which a translation actually exists. Forwarded to the
   * language switcher so it only links to working pages.
   */
  availableLocales?: readonly Locale[];
  /** Optional pre-calculated translation URLs for each locale. */
  translations?: Partial<Record<Locale, string>>;
}

const { locale, crumbs = [], availableLocales, translations } = Astro.props;
const t = useTranslations(locale);
const home = localizedPath('/', locale);
const avatar = SITE.author.avatar;
const isStringAvatar = typeof avatar === 'string';
const avatarSrc = isStringAvatar ? avatar.trim() : '';
---

<header class="chirpy-topbar" aria-label="Top Bar">
  <div class="flex flex-1 items-center gap-2 px-1">
    <button
      type="button"
      data-sidebar-toggle
      class="btn btn-ghost btn-sm btn-square lg:hidden"
      aria-label={t('nav.toggleMenu')}
    >
      <Icon name="lucide:menu" width={18} height={18} />
    </button>

    <nav aria-label="Breadcrumb" class="text-base-content/70 hidden truncate text-sm sm:block">
      <ol class="flex items-center gap-1">
        <li>
          <a href={home} class="hover:text-primary">{t('nav.home')}</a>
        </li>
        {
          crumbs.map((crumb, i) => (
            <li class="flex items-center gap-1 truncate">
              <span aria-hidden="true" class="text-base-content/40">
                /
              </span>
              {crumb.href && i < crumbs.length - 1 ? (
                <a href={crumb.href} class="hover:text-primary">
                  {crumb.label}
                </a>
              ) : (
                <span class="text-base-content truncate font-medium">{crumb.label}</span>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    {/* Mobile site title */}
    <a
      href={home}
      class="ml-1 flex items-center gap-2 truncate text-base font-semibold sm:hidden"
      aria-label={SITE.title}
    >
      {
        avatar ? (
          isStringAvatar ? (
            <Image
              src={avatarSrc.startsWith('/') ? withBase(avatarSrc) : avatarSrc}
              alt={SITE.author.name}
              width={24}
              height={24}
              densities={[1, 1.5, 2]}
              class="border-base-300 h-6 w-6 rounded-full border object-cover"
              loading="eager"
              decoding="async"
            />
          ) : (
            <Image
              src={avatar}
              alt={SITE.author.name}
              width={24}
              height={24}
              densities={[1, 1.5, 2]}
              class="border-base-300 h-6 w-6 rounded-full border object-cover"
              loading="eager"
              decoding="async"
            />
          )
        ) : null
      }
      <span>{SITE.title}</span>
    </a>
  </div>

  <div class="chirpy-topbar__search">
    <SearchButton locale={locale} />
    {
      SITE.multilingual && (
        <LanguageSwitcher
          locale={locale}
          availableLocales={availableLocales}
          translations={translations}
        />
      )
    }
  </div>
</header>
