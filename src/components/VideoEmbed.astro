---
/**
 * Responsive video embed for MDX content. Supports:
 *
 * 1. **Platform embeds** (iframe) — YouTube / Vimeo via `platform` + `id`:
 *      <VideoEmbed platform="youtube" id="dQw4w9WgXcQ" title="My video" />
 *      <VideoEmbed platform="vimeo" id="123456789" title="Vimeo clip" />
 *
 * 2. **Direct video files** (Plyr player) — via `src`:
 *      <VideoEmbed src="/videos/demo.mp4" title="Demo" />
 *      <VideoEmbed src="/videos/demo.mp4" title="Demo" poster="/img/thumb.jpg" />
 *
 * When `src` points to a direct video file, Plyr.js is loaded via CDN
 * and wraps a native <video> element for a polished playback experience.
 */

interface Props {
  /** Full iframe src URL (platform embed) OR direct video file URL. */
  src?: string;
  /** Video platform for shorthand usage with `id`. */
  platform?: 'youtube' | 'vimeo';
  /** Video ID (used with `platform`). */
  id?: string;
  /** Accessible title for the iframe / video. */
  title: string;
  /** Optional caption displayed below the video. */
  caption?: string;
  /** Optional poster image for direct video files. */
  poster?: string;
}

const { src, platform, id, title, caption, poster } = Astro.props;

/**
 * Determine whether `src` is a direct video file (to use Plyr)
 * or a platform embed URL (to use an iframe).
 */
const VIDEO_EXTENSIONS = /\.(mp4|webm|ogg|mov|m4v)(\?.*)?$/i;
const isDirectVideo = src && VIDEO_EXTENSIONS.test(src);
const isPlatformEmbed = Boolean(platform && id) || (src && !isDirectVideo);

function buildIframeSrc(): string {
  if (src && !isDirectVideo) return src;
  if (platform === 'youtube' && id) {
    return `https://www.youtube-nocookie.com/embed/${id}`;
  }
  if (platform === 'vimeo' && id) {
    return `https://player.vimeo.com/video/${id}`;
  }
  throw new Error('VideoEmbed: provide either `src` or both `platform` and `id`.');
}
---

<figure class="video-embed my-6">
  {
    isDirectVideo ? (
      <>
        <link rel="stylesheet" href="https://cdn.plyr.io/3.8.4/plyr.css" crossorigin="anonymous" />
        <div class="video-embed__plyr">
          <video class="plyr-video" playsinline controls data-plyr-title={title} poster={poster}>
            <source src={src} />
          </video>
        </div>
      </>
    ) : isPlatformEmbed ? (
      <div class="video-embed__frame">
        <iframe
          src={buildIframeSrc()}
          title={title}
          style="border: 0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          loading="lazy"
        />
      </div>
    ) : null
  }
  {
    caption && (
      <figcaption class="text-base-content/55 mt-2 text-center text-xs italic">
        {caption}
      </figcaption>
    )
  }
</figure>

<script>
  let plyrLoaded = false;

  async function loadPlyrScript(): Promise<void> {
    if (plyrLoaded) return;
    if (document.querySelector('script[src*="plyr.io"]')) {
      plyrLoaded = true;
      return;
    }
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdn.plyr.io/3.8.4/plyr.polyfilled.js';
      script.crossOrigin = 'anonymous';
      script.onload = () => {
        plyrLoaded = true;
        resolve();
      };
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  function initPlyrVideos() {
    const videos = document.querySelectorAll<HTMLVideoElement>('.plyr-video:not([data-plyr-init])');
    if (videos.length === 0) return;

    loadPlyrScript().then(() => {
      const Plyr = (window as unknown as Record<string, unknown>).Plyr as
        | (new (el: HTMLElement, opts?: Record<string, unknown>) => unknown)
        | undefined;
      if (!Plyr) return;

      videos.forEach((el) => {
        el.dataset.plyrInit = 'true';
        new Plyr(el, {
          controls: [
            'play-large',
            'play',
            'progress',
            'current-time',
            'mute',
            'volume',
            'settings',
            'pip',
            'fullscreen',
          ],
        });
      });
    });
  }

  initPlyrVideos();
  document.addEventListener('astro:page-load', initPlyrVideos);
</script>

<style>
  .video-embed__plyr {
    overflow: hidden;
    border-radius: 0.375rem;
    background: var(--color-sidebar-to);
  }
  .video-embed__plyr video {
    display: block;
    width: 100%;
  }
</style>
