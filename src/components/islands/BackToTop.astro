---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
---

<button type="button" class="back-to-top" aria-label={t('site.backToTop')} data-back-to-top>
  <Icon name="lucide:arrow-up" width={18} height={18} />
  <span class="back-to-top__text">{t('site.backToTop')}</span>
</button>

<script>
  function setupBackToTop() {
    const btn = document.querySelector<HTMLButtonElement>('[data-back-to-top]');
    if (!btn || btn.dataset.hasClickListener) return;

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    btn.dataset.hasClickListener = 'true';
  }
  setupBackToTop();
  document.addEventListener('astro:page-load', setupBackToTop);
</script>

<style>
  .back-to-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 30;
    display: flex;
    height: 2.75rem;
    width: 2.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid var(--color-base-300);
    background-color: var(--color-base-100);
    color: var(--color-base-content);
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.1),
      0 2px 4px -2px rgb(0 0 0 / 0.1);

    /* Default fallback states for browsers without scroll-driven animation support */
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);

    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  .back-to-top:hover {
    background-color: var(--color-base-200);
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  @supports (animation-timeline: scroll()) {
    .back-to-top {
      opacity: 0;
      pointer-events: none;
      transform: translateY(16px);
      animation: show-button linear both;
      animation-timeline: scroll();
      animation-range: 320px 321px;
    }
  }

  @keyframes show-button {
    from {
      opacity: 0;
      pointer-events: none;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }
  }

  /* Hide the text span by default (mobile / narrow desktop) */
  .back-to-top .back-to-top__text {
    display: none;
  }

  /* On xl+ (panel rail is visible): show a wider pill with text label,
     and align it with the right edge of the panel rail column so it sits
     neatly beside the main content — more visible, less tucked away. */
  @media (min-width: 1280px) {
    .back-to-top {
      height: auto;
      width: auto;
      gap: 0.375rem;
      border-radius: 9999px;
      padding: 0.625rem 1rem;
      /* Position it relative to the centered main shell and sidebar.
         For a wide viewport, we use the max() function to align it outside
         the right edge of the content shell. Fallback to 2rem on narrower viewports. */
      right: max(2rem, calc(50% - var(--current-sidebar-width) / 2 - 625px - 2.5rem));
    }
    .back-to-top .back-to-top__text {
      display: inline;
      font-size: 0.875rem;
      font-weight: 500;
    }
  }
</style>
