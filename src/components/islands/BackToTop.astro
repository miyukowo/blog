---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
---

<button type="button" class="chirpy-fab" aria-label={t('site.scrollToTop')} data-fab>
  <Icon name="lucide:arrow-up" width={18} height={18} />
  <span class="chirpy-fab__text">{t('site.scrollToTop')}</span>
</button>

<script>
  let activeScrollListener: (() => void) | null = null;

  function setupScrollToTop() {
    const btn = document.querySelector<HTMLButtonElement>('[data-fab]');
    if (!btn) return;
    const target = btn;

    if (activeScrollListener) {
      window.removeEventListener('scroll', activeScrollListener);
    }

    activeScrollListener = () => {
      if (window.scrollY > 320) target.classList.add('is-visible');
      else target.classList.remove('is-visible');
    };

    if (!target.dataset.hasClickListener) {
      target.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      target.dataset.hasClickListener = 'true';
    }

    window.addEventListener('scroll', activeScrollListener, { passive: true });
    activeScrollListener();
  }
  setupScrollToTop();
  document.addEventListener('astro:page-load', setupScrollToTop);
</script>

<style>
  @keyframes chirpy-fab-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .chirpy-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 30;
    display: flex;
    height: 2.75rem;
    width: 2.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid var(--color-base-300);
    background-color: var(--color-base-100);
    color: var(--color-base-content);
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.1),
      0 2px 4px -2px rgb(0 0 0 / 0.1);
    opacity: 0;
    pointer-events: none;
    /* No transition on opacity/transform — we use the keyframe instead */
    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  .chirpy-fab:hover {
    background-color: var(--color-base-200);
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .chirpy-fab.is-visible {
    opacity: 1;
    pointer-events: auto;
    animation: chirpy-fab-in 280ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  /* Hide the text span by default (mobile / narrow desktop) */
  .chirpy-fab .chirpy-fab__text {
    display: none;
  }

  /* On xl+ (panel rail is visible): show a wider pill with text label,
     and align it with the right edge of the panel rail column so it sits
     neatly beside the main content — more visible, less tucked away. */
  @media (min-width: 1280px) {
    .chirpy-fab {
      height: auto;
      width: auto;
      gap: 0.375rem;
      border-radius: 9999px;
      padding: 0.625rem 1rem;
      /* Position it relative to the centered main shell and sidebar.
         For a wide viewport, we use the max() function to align it outside
         the right edge of the content shell. Fallback to 2rem on narrower viewports. */
      right: max(2rem, calc(50% - var(--current-sidebar-width) / 2 - 625px - 2.5rem));
    }
    .chirpy-fab .chirpy-fab__text {
      display: inline;
      font-size: 0.875rem;
      font-weight: 500;
    }
  }
</style>
